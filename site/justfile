set shell := ["sh", "-cu"]
set working-directory := "."

root := ".."
host_family := os_family()
path_sep := if host_family == "windows" { ";" } else { ":" }
pixi_bin := if host_family == "windows" { root + "/.pixi/envs/default/Library/bin" } else { root + "/.pixi/envs/default/bin" }
export PATH := pixi_bin + path_sep + env("PATH")

# Zed's integrated terminal (and MSYS/Git Bash environments) can leak a
# Unix-style TEMP/TMP on Windows (e.g. `/tmp/zed-agent-terminal-XXXX`). Node's
# `os.tmpdir()` then resolves to a bare drive letter (e.g. `D:`) and pnpm
# crashes inside `realpathSync`. Force a Windows-style temp dir before any
# pnpm/node invocation on Windows hosts.
export TEMP := if host_family == "windows" { "D:/tmp/hikcamera-site" } else { env("TEMP", "/tmp") }
export TMP := if host_family == "windows" { "D:/tmp/hikcamera-site" } else { env("TMP", "/tmp") }
# pnpm otherwise prompts interactively when node_modules is stale.
export CI := "true"

install:
    pnpm install

dev:
    pnpm run dev

build:
    pnpm run build

check: build

test-e2e:
    pnpm run test:e2e

playwright-install:
    pnpm exec playwright install chromium

start:
    pnpm run start

clean:
    rm -rf .astro dist node_modules
