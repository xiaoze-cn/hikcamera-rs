set shell := ["sh", "-cu"]
set working-directory := "."

root := ".."

host_os := os()
host_family := os_family()
system := host_os

separator := if system == "windows" { ";" } else { ":" }

pixi_env := root + "/.pixi/envs/default"
pixi_bin := if system == "windows" { pixi_env + "/Library/bin" } else { pixi_env + "/bin" }
pnpm_bin := if system == "windows" { pixi_env + "/Library/share/pnpm/node_modules/.bin" } else { pixi_bin }

export PATH := if system == "windows" { pnpm_bin + separator + pixi_bin + separator + env("PATH") } else { pixi_bin + separator + env("PATH") }

local_temp := env("LOCALAPPDATA", root + "/.tmp") + "/Temp/hikcamera-site"
export TEMP := if system == "windows" { local_temp } else { env("TEMP", "/tmp") }
export TMP := if system == "windows" { local_temp } else { env("TMP", "/tmp") }

export CI := "true"

_default:
    @just --unsorted --list

[group('Setup')]
install: _temp
    pnpm install --no-frozen-lockfile

[group('Site')]
dev: _temp
    pnpm run dev

[group('Site')]
build: _temp
    pnpm run build

[group('Site')]
start: _temp
    pnpm run start

[group('Verify')]
check: build

[group('Tools')]
playwright-install:
    pnpm exec playwright install chromium

[group('Clean')]
clean:
    rm -rf .astro dist node_modules

_temp:
    @mkdir -p "$TEMP"
